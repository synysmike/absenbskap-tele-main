# Telegram Bot API token from @BotFather
API_TOKEN=your_telegram_bot_token_here

# Presensi (presensi.bskap.id): per-user id_user, password, lokasi, lokasi_cabang
# Commands: <name>_in / <name>_out  e.g. teguh_in, teguh_out
# Schedule: <name>_in;DDmonYYYY;HH:MM  e.g. teguh_in;09mar2026;07:17

# --- TEGUH ---
TEGUH_USER_ID=your_id_user
TEGUH_PASSWORD=your_password
TEGUH_LOKASI=Jakarta
TEGUH_LOKASI_CABANG=-7.311234,112.721201

